# GoRent Backend Environment Variables
# Copy this file to .env and fill in your values

# ===========================================
# REQUIRED VARIABLES
# ===========================================

# MongoDB Connection String (from MongoDB Atlas)
# Format: mongodb+srv://username:password@cluster.mongodb.net/gorent?retryWrites=true&w=majority
MONGO_URI=mongodb+srv://your_mongodb_connection_string

# JWT Secret for token generation
# Use a strong random string (at least 32 characters)
# You can generate one at: https://generate-random-string.com/
JWT_SECRET=your_super_secret_jwt_key_min_32_characters

# ===========================================
# OPTIONAL VARIABLES
# ===========================================

# Server Port (default: 5000)
PORT=5000

# Node Environment (development or production)
NODE_ENV=development

# ===========================================
# IMAGEKIT CONFIGURATION (Optional)
# ===========================================
# Only required if you want to use ImageKit for image uploads
# Get your credentials from https://imagekit.io/
# IMAGEKIT_PUBLIC_KEY=your_public_key
# IMAGEKIT_PRIVATE_KEY=your_private_key
# IMAGEKIT_URL_ENDPOINT=https://ik.imagekit.io/your_imagekit_id

# ===========================================
# RENDER DEPLOYMENT NOTES
# ===========================================
# When deploying to Render:
# 1. Set PORT to 10000 (Render assigns this)
# 2. Set NODE_ENV to production
# 3. Make sure Mongo_URI points to MongoDB Atlas
# 4. Keep JWT_SECRET consistent across deployments
# 5. Add the following Build Command: npm install
# 6. Add the following Start Command: npm start

